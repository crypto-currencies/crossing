generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Role hierarchy ───────────────────────────────────────────────────────────
// USER      — every new account
// MODERATOR — can review submissions/reports; cannot modify users
// ADMIN     — full moderation access; cannot modify OWNER accounts
// OWNER     — platform owner(s); unrestricted
enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

model User {
  id       String   @id @default(cuid())
  name     String?
  email    String?  @unique
  image    String?
  role     UserRole @default(USER)
  verified Boolean  @default(false)

  onboardingCompleted Boolean   @default(false)
  passwordHash        String?
  passwordChangedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  securityEvents SecurityEvent[]
  notifications  Notification[]

  // Suspend state — set by admin actions
  suspendedAt     DateTime?
  suspendedReason String?
  // Role tracking — who last changed this user's role and when
  roleChangedAt   DateTime?
  roleGrantedById String? // adminId who made the last role change
  // Email verification — set when the user clicks the verification link.
  // Null for accounts created before this feature or via OAuth (already verified by provider).
  emailVerifiedAt DateTime?

  preferences UserPreferences?

  submissions         Submission[] @relation("SubmittedBy")
  reviewedSubmissions Submission[] @relation("ReviewedBy")
  submittedListings   Listing[]    @relation("ListingSubmittedBy")
  approvedListings    Listing[]    @relation("ListingApprovedBy")
  saves               Save[]
  votes               Vote[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Device metadata (captured at session creation)
  userAgent    String?
  ipHash       String? // SHA-256 of client IP — never returned to client
  maskedIp     String? // Display-safe partial IP (e.g. "104.28.xx.xx")
  deviceHint   String? // "Chrome on macOS", "Safari on iOS", etc.
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Notification ─────────────────────────────────────────────────────────────
// System-generated notifications (e.g. submission approved/rejected). No
// user-to-user "actor" concept — Crossing.dev has no social graph.

model Notification {
  id     String @id @default(cuid())
  userId String // recipient
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String // NotificationType
  title String
  body  String
  href  String?
  read  Boolean @default(false)

  entityId   String?
  entityType String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
}

// ─── Admin Audit Log ─────────────────────────────────────────────────────────
// Records every destructive admin action for accountability and rollback.
// adminId / targetUserId are plain string FKs — no Prisma relation needed
// since we query by raw ID and don't need join-time type safety here.

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String // "verify.grant" | "verify.revoke" | "suspend" | "unsuspend" | "role.grant" | "role.revoke"
  targetUserId String?
  metadata     Json? // snapshot of changed fields
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt(sort: Desc)])
}

// ─── Security Events ──────────────────────────────────────────────────────────
// Append-only log of security-relevant actions on a user account.
// Shown in Settings → Security → Security log.

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String // "login" | "login_failed" | "password_set" | "password_changed" | ...
  metadata  Json? // optional context (masked IP string, device hint, etc.)
  ipHash    String? // SHA-256 of client IP (not reversible; used for display bucketing only)
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── User Preferences ────────────────────────────────────────────────────────
// Per-user notification preferences. One row per user, created on first PATCH.

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailNotifications Boolean @default(true)
  pushEnabled        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Password Reset Tokens ────────────────────────────────────────────────────
// Single-use tokens for the forgot-password flow.
// The token is stored as a SHA-256 hex hash — never in plain text.
// Tokens expire after 1 hour and are consumed (usedAt set) on use.

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String // the address the reset was requested for
  tokenHash String    @unique // SHA-256 of the plain-text URL token
  expiresAt DateTime
  usedAt    DateTime? // null = unused
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// Discovery domain — categories, listings, submissions, saves, votes
// ═══════════════════════════════════════════════════════════════════════════
//
// Flow: a user creates a Submission (an untrusted, user-authored proposal).
// A moderator/admin approves or rejects it. Approving CREATES a new Listing
// — the Submission row is never mutated into a Listing in place — so the
// originally-submitted content stays intact as a permanent audit trail even
// if the published Listing is later edited directly by an admin. Rejecting
// just marks the Submission REJECTED and no Listing is ever created for it,
// which is what keeps rejected content out of every public query for free:
// public reads only ever select from Listing, never from Submission.

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// Listings have no PENDING/REJECTED state of their own — unapproved content
// never becomes a Listing at all (see flow note above). ARCHIVED is the only
// post-publish moderation action: pulling a previously-published listing
// from public view without deleting its history.
enum ListingStatus {
  PUBLISHED
  ARCHIVED
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String? // lucide-react icon name, resolved client-side
  position    Int     @default(0) // manual display order, lowest first
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings    Listing[]
  submissions Submission[]

  @@index([isActive, position])
}

model Listing {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  tagline       String
  description   String
  websiteUrl    String // display URL, as submitted
  websiteUrlKey String        @unique // normalized form — enforces one listing per site
  logoUrl       String?
  coverImageUrl String?
  status        ListingStatus @default(PUBLISHED)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Nullable + SetNull: published content must survive its submitter's or
  // approver's account being deleted — it isn't their personal data anymore.
  submittedById String?
  submittedBy   User?     @relation("ListingSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  approvedById  String?
  approvedBy    User?     @relation("ListingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  publishedAt   DateTime  @default(now())

  // Cached ranking signals — denormalized counters kept in sync by the
  // save/vote data-access functions (features/saves, features/votes), not
  // derived ad hoc per query. rankingScore is recomputed periodically by
  // features/listings/ranking.ts, not on every mutation. See docs/ranking-v0.md.
  saveCount      Int   @default(0)
  voteCount      Int   @default(0)
  viewCount      Int   @default(0)
  rankingScore   Float @default(0)
  // Manual editorial nudge, strictly capped — see docs/ranking-v0.md.
  editorialBoost Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submission Submission?
  saves      Save[]
  votes      Vote[]

  @@index([status, categoryId])
  @@index([status, rankingScore(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
}

// A user-authored proposal for a new listing. Preserved permanently as
// originally submitted, independent of moderation outcome — see flow note above.
model Submission {
  id            String           @id @default(cuid())
  name          String
  websiteUrl    String
  websiteUrlKey String // normalized form — checked (not uniquely constrained) for duplicate warnings
  tagline       String
  description   String
  status        SubmissionStatus @default(PENDING)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  submittedById String
  submittedBy   User   @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: Cascade)

  moderatorNote String?
  reviewedById  String?
  reviewedBy    User?     @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?

  // Set only once APPROVED — the Listing this submission produced.
  listingId String?  @unique
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([submittedById])
  @@index([status, createdAt(sort: Desc)])
  @@index([websiteUrlKey])
}

// A private bookmark — no public or ranking signal. One save per user per listing.
model Save {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}

// A lightweight positive signal ("recommend this"). Feeds ranking. One vote per user per listing.
model Vote {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}
