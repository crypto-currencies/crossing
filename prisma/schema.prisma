generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Role hierarchy ───────────────────────────────────────────────────────────
// USER      — every new account
// MODERATOR — can view reports and act on content; cannot modify users
// ADMIN     — full moderation access; cannot modify OWNER accounts
// OWNER     — platform owner(s); unrestricted
enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String? @unique
  image    String?
  role     UserRole @default(USER)
  verified Boolean  @default(false)

  onboardingCompleted Boolean   @default(false)
  passwordHash        String?
  passwordChangedAt   DateTime?

  // Two-factor authentication (TOTP)
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String? // active TOTP secret (base32); never sent to client after setup
  twoFactorPendingSecret String? // pending setup secret, replaced on new setup attempt
  twoFactorEnabledAt     DateTime?
  twoFactorLastUsedStep  Int?    // last TOTP time-step counter consumed; blocks replays within the same window

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  backupCodes    UserBackupCode[]
  securityEvents SecurityEvent[]
  notifications      Notification[] @relation("NotifRecipient")
  actorNotifications Notification[] @relation("NotifActor")

  // Moderation
  reports               Report[]
  supportTickets        SupportTicket[]
  supportTicketMessages SupportTicketMessage[]

  // Suspend state — set by admin actions
  suspendedAt     DateTime?
  suspendedReason String?
  // Role grant tracking — who last changed this user's role and when
  roleChangedAt   DateTime?
  roleGrantedById String? // adminId who made the last role change
  // Soft-delete: set when the user requests account deletion.
  // A background job hard-deletes the account 7 days after this timestamp.
  // Cleared if the user cancels before the window expires.
  deletionScheduledAt DateTime?
  // Email verification — set when the user clicks the verification link.
  // Null for accounts created before this feature or via OAuth (already verified by provider).
  emailVerifiedAt DateTime?

  preferences UserPreferences?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Device metadata (captured at session creation)
  userAgent    String?
  ipHash       String? // SHA-256 of client IP — never returned to client
  maskedIp     String? // Display-safe partial IP (e.g. "104.28.xx.xx")
  deviceHint   String? // "Chrome on macOS", "Safari on iOS", etc.
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Short-lived token issued after password verification when 2FA is enabled.
// Allows the client to complete the TOTP challenge in a separate request
// without receiving a full session token until TOTP succeeds.
model PendingLogin {
  id             String   @id @default(cuid())
  tokenHash      String   @unique // SHA-256 of the plain token sent to the client
  userId         String
  expiresAt      DateTime
  failedAttempts Int      @default(0) // Deleted after 5 wrong codes — prevents TOTP brute-force
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id     String @id @default(cuid())
  userId String // recipient
  user   User   @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)

  type  String // NotificationType
  title String
  body  String
  href  String?
  read  Boolean @default(false)

  // Optional actor metadata (denormalized for display without extra join)
  actorId       String?
  actorUsername String?
  actorAvatar   String?
  actor         User?   @relation("NotifActor", fields: [actorId], references: [id], onDelete: SetNull)

  entityId   String?
  entityType String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
}

// ─── Moderation ────────────────────────────────────────────────────────────────

model Report {
  id           String    @id @default(cuid())
  reporterId   String
  targetUserId String?
  reason       String
  subject      String? // optional short title
  details      String    @default("")
  status       String    @default("pending") // "pending" | "under_review" | "resolved" | "dismissed"
  priority     String    @default("low") // "low" | "medium" | "high" | "urgent"
  adminNote    String?
  metadata     Json?
  resolvedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([targetUserId])
  @@index([status])
  @@index([priority])
  @@index([createdAt(sort: Desc)])
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

model SupportTicket {
  id           String    @id @default(cuid())
  userId       String
  category     String // "account" | "upload" | "appeal" | "bug" | "other"
  status       String    @default("open") // "open" | "under_review" | "awaiting_user" | "resolved" | "dismissed"
  priority     String    @default("low") // "low" | "medium" | "high" | "urgent"
  subject      String
  metadata     Json?
  resolvedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportTicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt(sort: Desc)])
}

model SupportTicketMessage {
  id       String  @id @default(cuid())
  ticketId String
  senderId String
  body     String
  isAdmin  Boolean @default(false) // true = sent by an admin/moderator

  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([ticketId, createdAt(sort: Asc)])
}

// ─── Admin Audit Log ─────────────────────────────────────────────────────────
// Records every destructive admin action for accountability and rollback.
// adminId / targetUserId are plain string FKs — no Prisma relation needed
// since we query by raw ID and don't need join-time type safety here.

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String // "verify.grant" | "verify.revoke" | "suspend" | "unsuspend" | "role.grant" | "role.revoke"
  targetUserId String?
  metadata     Json? // snapshot of changed fields
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt(sort: Desc)])
}

// ─── Admin Step-Up Verification ───────────────────────────────────────────────
// Two-layer protection for sensitive admin actions.
//
// AdminVerificationChallenge — one-time email OTP.
//   The 6-digit code is SHA-256 hashed before storage.
//   Expires in 10 minutes, single-use, max 5 wrong-code attempts before invalidation.
//
// AdminVerificationSession — tracks the verified window (10 min) after a
//   successful challenge. All sensitive routes check this table server-side.
//   Client cannot claim verified status; the DB is the only truth.

model AdminVerificationChallenge {
  id        String    @id @default(cuid())
  adminId   String
  codeHash  String
  purpose   String    @default("step_up")
  attempts  Int       @default(0) // wrong-code attempts; invalidated at 5
  expiresAt DateTime
  usedAt    DateTime? // null = unused
  createdAt DateTime  @default(now())

  @@index([adminId])
  @@index([adminId, purpose])
  @@index([expiresAt])
}

model AdminVerificationSession {
  id        String   @id @default(cuid())
  adminId   String   @unique // one active session per admin
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model RoleGrantCode {
  id           String   @id @default(cuid())
  codeHash     String // SHA-256 hex of the 6-digit numeric code
  ownerId      String // the OWNER who requested the change
  targetUserId String // the user whose role is changing
  targetRole   String // "ADMIN" | "MODERATOR" | "USER"
  action       String // "grant" | "revoke"
  used         Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([ownerId])
  @@index([targetUserId])
  @@index([expiresAt])
}

// ─── User Backup Codes ────────────────────────────────────────────────────────
// One-time use recovery codes generated when TOTP 2FA is enabled.
// The plaintext code is shown once and never stored; only the bcrypt hash is kept.
// Used codes have usedAt set; unused codes have usedAt null.

model UserBackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String // bcrypt hash of the plain-text code
  usedAt    DateTime? // null = unused; set when the code is consumed
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, usedAt])
}

// ─── Security Events ──────────────────────────────────────────────────────────
// Append-only log of security-relevant actions on a user account.
// Shown in Settings → Security → Security log.

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String // "login" | "login_failed" | "password_set" | "password_changed" | "totp_enabled" | ...
  metadata  Json? // optional context (masked IP string, device hint, etc.)
  ipHash    String? // SHA-256 of client IP (not reversible; used for display bucketing only)
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── User Preferences ────────────────────────────────────────────────────────
// Per-user notification preferences. One row per user, created on first PATCH.

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailNotifications Boolean @default(true)
  pushEnabled        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Password Reset Tokens ────────────────────────────────────────────────────
// Single-use tokens for the forgot-password flow.
// The token is stored as a SHA-256 hex hash — never in plain text.
// Tokens expire after 1 hour and are consumed (usedAt set) on use.

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String // the address the reset was requested for
  tokenHash String    @unique // SHA-256 of the plain-text URL token
  expiresAt DateTime
  usedAt    DateTime? // null = unused
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}
